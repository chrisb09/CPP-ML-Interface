@startuml CPP_NEW_ML_Interface

' Layout hints to encourage a tree-like rendering
top to bottom direction
' skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam backgroundColor #FFFFFF
skinparam class {
    BackgroundColor<<abstract>> LightYellow
    BorderColor Black
    ArrowColor Black
}


class "MLCoupling<In,Out>" {
    - parameters: std::vector<void*>
    - provider: std::unique_ptr<MLCouplingProvider<In,Out>>
    - application: std::unique_ptr<MLCouplingApplication<In,Out>>
    - behavior: std::unique_ptr<MLCouplingBehavior>
    + MLCoupling(MLCouplingProvider<In,Out>*,
                 MLCouplingApplication<In,Out>*, MLCouplingBehavior* = nullptr)
    + ~MLCoupling()
    + ml_step()
    + create_mlcoupling_from_config(...) <<static>>
    # set_parameters(std::vector<void*>)
}

class "MLCouplingProvider<In,Out>" <<abstract>> {
    + rank: int
    + MLCouplingProvider()
    + MLCouplingProvider(int)
    + set_rank(int)
    + inference(MLCouplingData<In>, MLCouplingData<Out>&)
}

class "MLCouplingProviderFlexible<In,Out>" <<abstract>> {
    + MLCouplingProviderFlexible()
    + send_data(MLCouplingData<In>)
}

class "MLCouplingApplication<In,Out>" <<abstract>> {
    + input_data: MLCouplingData<In>
    + input_data_after_preprocessing: MLCouplingData<In>
    + output_data_before_postprocessing: MLCouplingData<Out>
    + output_data: MLCouplingData<Out>
    # normalization: std::unique_ptr<MLCouplingNormalization<In,Out>>
    + MLCouplingApplication(std::vector<In*>, std::vector<std::vector<int>>,
                            std::vector<Out*>, std::vector<std::vector<int>>,
                            MLCouplingNormalization<In,Out>*)
    + MLCouplingApplication(MLCouplingData<In>, MLCouplingData<Out>,
                            MLCouplingNormalization<In,Out>*)
    + MLCouplingApplication(MLCouplingData<In>, MLCouplingData<In>,
                            MLCouplingData<Out>, MLCouplingData<Out>,
                            MLCouplingNormalization<In,Out>*)
    + step(bool, bool)
    # preprocess(MLCouplingData<In>): MLCouplingData<In>
    # coupling_step(MLCouplingData<In>)
    # ml_step(MLCouplingData<In>): MLCouplingData<Out>
    # postprocess(MLCouplingData<Out>): MLCouplingData<Out>
}

class "MLCouplingNormalization<In,Out>" <<abstract>> {
    + normalize_input(MLCouplingData<In>)
    + denormalize_output(MLCouplingData<Out>)
    + print(std::ostream&)
    + ~MLCouplingNormalization()
}

class "MLCouplingMinMaxNormalization<In,Out>" {
    - input_min: In
    - input_max: In
    - output_min: Out
    - output_max: Out
    + MLCouplingMinMaxNormalization(In, In, Out, Out)
    + MLCouplingMinMaxNormalization(In*, int, Out*, int)
    + MLCouplingMinMaxNormalization(MLCouplingData<In>, MLCouplingData<Out>)
    + normalize_input(In*, int)
    + normalize_input(MLCouplingData<In>)
    + denormalize_output(Out*, int)
    + denormalize_output(MLCouplingData<Out>)
    + print(std::ostream&)
}

class "MLCouplingApplicationTurbulenceClosure<In,Out>" {
    # preprocess(MLCouplingData<In>): MLCouplingData<In>
    # coupling_step(MLCouplingData<In>)
    # ml_step(MLCouplingData<In>): MLCouplingData<Out>
    # postprocess(MLCouplingData<Out>): MLCouplingData<Out>
    - uniform_filtering()
    - downsampling()
    - compute_tau_ij()
}

class "MLCouplingBehavior" <<abstract>> {
    + should_perform_inference(): bool
    + time_step_delta(): int
    + should_send_data(): bool
}

class "MLCouplingBehaviorDefault" {
    + should_perform_inference(): bool
    + time_step_delta(): int
    + should_send_data(): bool
}

class "MLCouplingBehaviorPeriodic" {
    - step_count: long long
    - inference_interval: int
    - coupled_steps_before_inference: int
    - coupled_steps_stride: int
    - step_increment_after_inference: int
    - prohibit_inference: std::function<bool(int)>
    + MLCouplingBehaviorPeriodic(int, int, int, int,
                                 std::function<bool(int)> = allow_inference_at_all_steps)
    + should_perform_inference(): bool
    + time_step_delta(): int
    + should_send_data(): bool
}

class "MLCouplingProviderPhydll<In,Out>" {
    + send_data(MLCouplingData<In>)
    + inference(MLCouplingData<In>, MLCouplingData<Out>&)
}

class "MLCouplingProviderAixelerator<In,Out>" {
    - model_file: std::string
    - batchsize: int
    - app_comm: MPI_Comm
    - enable_hybrid: bool
    - host_fraction: std::optional<float>
    + MLCouplingProviderAixelerator(std::string, int = 1, MPI_Comm = MPI_COMM_WORLD,
                                    bool = false, std::optional<float> = std::nullopt)
    + inference(MLCouplingData<In>, MLCouplingData<Out>&)
}

class "MLCouplingProviderSmartsim<In,Out>" {
    - device: std::string
    - model_backend: std::string
    - model_name: std::string
    - num_gpus: int
    - first_gpu: int
    - batch_size: int
    - min_batch_size: int
    - min_batch_timeout: int
    + MLCouplingProviderSmartsim(std::string, std::string, std::string,
                                 std::string = "model", std::string = "localhost",
                                 int = 6379, int = 1, int = 0, int = 0,
                                 int = 0, int = 0, int = 0,
                                 std::vector<std::string> = {}, std::vector<std::string> = {})
    + MLCouplingProviderSmartsim(std::string, std::string, std::string_view,
                                 std::string = "model", std::string = "localhost",
                                 int = 6379, int = 1, int = 0, int = 0,
                                 int = 0, int = 0, int = 0,
                                 std::vector<std::string> = {}, std::vector<std::string> = {})
    + validate_parameter(...)
    + send_data(MLCouplingData<In>)
    + inference(MLCouplingData<In>, MLCouplingData<Out>&)
}

class "MLCouplingTensor<T>" {
    - root: void*
    - dimensions: std::vector<int>
    - layout: MLCouplingMemoryLayout
    - ownership: MLCouplingOwnership
    + MLCouplingTensor()
    + MLCouplingTensor(void*, std::vector<int>, MLCouplingMemoryLayout,
                       MLCouplingOwnership = MLCouplingOwnershipExternal)
    + wrap_flat(T*, std::vector<int>, MLCouplingMemoryLayout = MLCouplingMemLayoutContiguous,
                MLCouplingOwnership = MLCouplingOwnershipExternal)
    + wrap_nested(void*, std::vector<int>, MLCouplingMemoryLayout = MLCouplingMemLayoutNested,
                  MLCouplingOwnership = MLCouplingOwnershipExternal)
    + from_flat_copy(std::vector<T>, std::vector<int>,
                     MLCouplingMemoryLayout = MLCouplingMemLayoutContiguous)
    + dimensions(): const std::vector<int>&
    + layout(): MLCouplingMemoryLayout
    + ownership(): MLCouplingOwnership
    + root(): void*
    + numel(): size_t
    + data_type(): MLCouplingDataType
    + flatten(MLCouplingMemoryLayout): MLCouplingTensor<T>
    + unflatten(MLCouplingMemoryLayout): MLCouplingTensor<T>
}

class "MLCouplingMatrix<T>" {
    + MLCouplingMatrix(T*, int, int)
    + MLCouplingMatrix(std::vector<std::vector<T>>)
}

class "MLCouplingVector<T>" {
    + MLCouplingVector(T*, int)
    + MLCouplingVector(std::vector<T>)
}

class "MLCouplingScalar<T>" {
    + MLCouplingScalar(T)
    + MLCouplingScalar(T*)
}

class "MLCouplingData<T>" {
    - tensors: std::vector<MLCouplingTensor<T>>
    + MLCouplingData()
    + MLCouplingData(std::vector<MLCouplingTensor<T>>)
    + add_tensor(MLCouplingTensor<T>)
    + size(): size_t
    + empty(): bool
    + operator[](size_t): MLCouplingTensor<T>&
    + flatten_all(MLCouplingMemoryLayout = MLCouplingMemLayoutContiguous): MLCouplingData<T>
    + deep_copy(): MLCouplingData<T>
    + get_flat_data(): std::vector<T>
}

enum "MLCouplingOwnership" {
    MLCouplingOwnershipExternal
    MLCouplingOwnershipOwned
}

enum "MLCouplingMemoryLayout" {
    MLCouplingMemLayoutInvalid
    MLCouplingMemLayoutNested
    MLCouplingMemLayoutContiguous
    MLCouplingMemLayoutFortranNested
    MLCouplingMemLayoutFortranContiguous
}

enum "MLCouplingDataType" {
    MLCouplingDataTypeInvalid
    MLCouplingDataTypeDouble
    MLCouplingDataTypeFloat
    MLCouplingDataTypeInt8
    MLCouplingDataTypeInt16
    MLCouplingDataTypeInt32
    MLCouplingDataTypeInt64
    MLCouplingDataTypeUint8
    MLCouplingDataTypeUint16
}

' Relationships
"MLCoupling<In,Out>" "1" ||--|| "1" "MLCouplingProvider<In,Out>" : owns
"MLCoupling<In,Out>" "1" ||--|| "1" "MLCouplingApplication<In,Out>" : owns
"MLCoupling<In,Out>" "1" ||--o| "0..1" "MLCouplingBehavior" : owns
"MLCouplingApplication<In,Out>" "1" ||--o| "0..1" "MLCouplingNormalization<In,Out>" : owns
"MLCouplingApplication<In,Out>" "1" o--|| "4" "MLCouplingData<T>" : uses
"MLCouplingNormalization<In,Out>" <|-- "MLCouplingMinMaxNormalization<In,Out>"

"MLCouplingApplication<In,Out>" <|-- "MLCouplingApplicationTurbulenceClosure<In,Out>"
"MLCouplingBehavior" <|-- "MLCouplingBehaviorDefault"
"MLCouplingBehavior" <|-- "MLCouplingBehaviorPeriodic"

"MLCouplingProvider<In,Out>" <|-- "MLCouplingProviderFlexible<In,Out>"
"MLCouplingProviderFlexible<In,Out>" <|-- "MLCouplingProviderPhydll<In,Out>"
"MLCouplingProvider<In,Out>" <|-- "MLCouplingProviderAixelerator<In,Out>"
"MLCouplingProviderFlexible<In,Out>" <|-- "MLCouplingProviderSmartsim<In,Out>"

"MLCouplingData<T>" "1" o--|| "0..*" "MLCouplingTensor<T>" : owns
"MLCouplingTensor<T>" <|-- "MLCouplingMatrix<T>"
"MLCouplingTensor<T>" <|-- "MLCouplingVector<T>"
"MLCouplingTensor<T>" <|-- "MLCouplingScalar<T>"

@enduml